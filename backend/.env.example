# ── Server ──────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/foodtruth

# ── JWT ─────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Anthropic (AI truth engine) ──────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Open Food Facts (free, no key needed) ────────
OPEN_FOOD_FACTS_URL=https://world.openfoodfacts.org

# ── Frontend URLs ────────────────────────────────
FRONTEND_URL=http://localhost:3000
MOBILE_URL=http://localhost:3001
